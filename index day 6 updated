    <style>
        body {
            font-family : Arial,sans-serif;
            background-color : #f4f6f9;
        }

        .card{
            background-color: white;
            width : 700px;
            padding : 20px;
            margin : 50px auto;
            border : none;
            border-radius: 15px;

            box-shadow: 0px 0px 10px gray;
            transition: 0.3s;
        }
        .card:hover{
            transform: scale(1.02);
        }
        .navbar{
            background-color: #2c3e50;
            padding: 15px;
            text-align: center;
            margin-bottom: 20px;
        }
        .navbar a{
            color: white;
            text-decoration: none;
            margin: 0 20px;
            font-weight: bold;
        }
        .navbar a:hover{
            color: #3498db;
        }
        .button{
            background-color: green;
            color: white;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 8px;   
        }
        .button:hover{
            background-color: orange;
        }
        .profile-pic{
            width: 150px;
            height: 150px;
            border-radius: 50%;
            display: block;
            margin: 0 auto;
            border: 3px solid blue;
            object-fit: cover;
            transition: 0.3s;
        }
        .profile-pic:hover{
            transform: scale(1.05);
        }
        .about{
            line-height: 1.6;
            text-align: justify;
        }
        .bar{
            width: 100%;
            background-color: lightgray;
            border-radius: 10p;
            margin-bottom: 15px;
        }
        .bar div{
            height: 20px;
            border-radius: 10px;
        }
        .python{
            width: 85%;
            background-color: green;
        }
        .sql{
            width: 80%;
            background-color: orange;
        }
        .html{
            width: 75%;
            background-color: blue;
        }
        .css{
            width: 70%;
            background-color: purple;
        }
        .flask{
            width: 65%;
            background-color: red;
        }
        h1{
            color : #2c3e50;
            text-align: center;
        }
        h2{
            color : #3498db;
            border-bottom: 2px solid green;
            padding-bottom: 5px;
        }
        .profession{
            text-align: center;
        }
        table{
            width: 100%;
            border-collapse: collapse;
        }
        th,td{
            border: 1px solid gray ;
            padding: 10px;
            text-align: center;
        }
        th{
            background-color: lightblue;
        }
        tr:hover td{
            background-color: #2f2f2;
            transition: 0.3s;
        }
        .project-card{
            border: 1px solid lightgray;
            padding: 15px;
            margin-top: 10px;
            border-radius: 10px;
            box-shadow: 0px 0px 5px lightgray;
        }
        .project-card:hover{
            transform: scale(1.02);
            transition: 0.3s;
        }
        input, textarea{
            width: 100%;
            padding: 8px;
            margin-top: 5px;
            margin-bottom: 10px;
            border: 1px solid gray;
            border-radius: 5px;

        }
        input[type="submit"]{
            background-color: green;
            color: white;
            border: none;
            cursor: pointer;
        }
        input[type="submit"]:hover{
            background-color: orange;
        }
        table tr:nth-child(even){
            background-color: #f9f9f9;
        }
       
        footer{
            color: gray;
            text-align: center;
            margin-top: 20px ;
            font-size: 14px;
        }
    </style>
</head>
