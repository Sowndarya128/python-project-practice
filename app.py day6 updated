from flask import Flask,render_template
import pyodbc

app = Flask(__name__)

@app.route("/")
def home():
    conn = pyodbc.connect(
    "DRIVER={ODBC Driver 17 for SQL Server};"
    "SERVER=STUNNER;"
    "DATABASE=StudentDB;"
    "Trusted_Connection=yes;"
    )

    cursor = conn.cursor()

    cursor.execute("SELECT * FROM Employee")

    employees = cursor.fetchall()

    total = len(employees)
    return render_template(
    "index.html",
    employees=employees,
    total=total
