import pyodbc

conn = pyodbc.connect(
    "DRIVER={ODBC Driver 17 for SQL Server};"
    "SERVER=STUNNER;"
    "DATABASE=StudentDB;"
    "Trusted_Connection=yes;"
)

print("Connection Successful!")

cursor = conn.cursor()

cursor.execute("SELECT * FROM Employee")

rows = cursor.fetchall()

for row in rows:
    print(row)

conn.close()
